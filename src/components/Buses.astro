---
---
<section id="autobuses" class="buses-section">
  <div class="container">
    <h2 class="section-title reveal">Autobuses</h2>
    <div class="section-divider reveal"><span>✦</span></div>

    <p class="buses-intro reveal">
      Para que podáis disfrutar sin preocupaciones, hemos organizado autobuses de ida y vuelta.
      Los horarios exactos os los confirmaremos próximamente.
    </p>

    <div class="buses-list">

      <!-- Bus 1: Kiosko de Rafa → El Comercial -->
      <div class="bus-row-card reveal">
        <div class="bus-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="8" width="28" height="18" rx="3" stroke="currentColor" stroke-width="1.3" fill="none"/>
            <path d="M4 14h28" stroke="currentColor" stroke-width="1.3"/>
            <line x1="16" y1="8" x2="16" y2="26" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="10" cy="28" r="2.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
            <circle cx="26" cy="28" r="2.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
          </svg>
        </div>
        <div class="bus-stops">
          <span class="bus-stop">Kiosko de Rafa</span>
          <span class="bus-arrow">→</span>
          <span class="bus-stop">El Comercial</span>
        </div>
        <dl class="bus-info">
          <div class="bus-detail">
            <dt>Salida</dt>
            <dd>--:-- h</dd>
          </div>
          <div class="bus-detail">
            <dt>Regreso</dt>
            <dd>--:-- h</dd>
          </div>
        </dl>
      </div>

      <!-- Bus 2: Jerez -->
      <div class="bus-row-card reveal">
        <div class="bus-icon" aria-hidden="true">
          <svg width="32" height="32" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="8" width="28" height="18" rx="3" stroke="currentColor" stroke-width="1.3" fill="none"/>
            <path d="M4 14h28" stroke="currentColor" stroke-width="1.3"/>
            <line x1="16" y1="8" x2="16" y2="26" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="10" cy="28" r="2.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
            <circle cx="26" cy="28" r="2.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
          </svg>
        </div>
        <div class="bus-stops">
          <span class="bus-stop">Jerez</span>
        </div>
        <dl class="bus-info">
          <div class="bus-detail">
            <dt>Salida</dt>
            <dd>--:-- h</dd>
          </div>
          <div class="bus-detail">
            <dt>Regreso</dt>
            <dd>--:-- h</dd>
          </div>
        </dl>
      </div>

    </div>
  </div>
</section>

<style>
  .buses-section {
    padding: var(--section-padding);
    background: var(--color-bg);
  }

  .buses-intro {
    max-width: 560px;
    margin: 0 auto 3rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .buses-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 640px;
    margin: 0 auto;
  }

  .bus-row-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    border: 1px solid var(--color-border);
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .bus-row-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(110,123,99,0.1);
  }

  .bus-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .bus-stops {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .bus-stop {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text);
  }

  .bus-arrow {
    color: var(--color-accent);
    font-size: 0.85rem;
    opacity: 0.7;
  }

  .bus-info {
    display: grid;
    grid-template-columns: auto auto;
    gap: 0.3rem 1.2rem;
    font-size: 0.82rem;
    text-align: right;
  }

  .bus-detail { display: contents; }

  .bus-detail dt {
    color: var(--color-text);
    font-weight: 500;
    text-align: right;
  }

  .bus-detail dd {
    color: var(--color-text-light);
    text-align: left;
  }

  @media (max-width: 560px) {
    .bus-row-card {
      grid-template-columns: auto 1fr;
      grid-template-rows: auto auto;
    }

    .bus-info {
      grid-column: 1 / -1;
      text-align: left;
    }
  }
</style>
