---
---
<section id="banquete" class="event-section">
  <div class="container">
    <h2 class="section-title reveal">El Banquete</h2>
    <div class="section-divider reveal"><span>✦</span></div>

    <div class="event-card reveal">
      <div class="event-icon" aria-hidden="true">
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 12 Q22 7 34 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none"/>
          <path d="M10 12 L10 32 Q22 37 34 32 L34 12" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" fill="none"/>
          <line x1="22" y1="37" x2="22" y2="41" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <line x1="16" y1="41" x2="28" y2="41" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <path d="M16 22 Q22 25 28 22" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none"/>
        </svg>
      </div>

      <h3 class="event-name">Finca Los Azahares</h3>

      <dl class="event-info">
        <div class="event-row">
          <dt>Hora</dt>
          <dd>14:30 h</dd>
        </div>
        <div class="event-row">
          <dt>Formato</dt>
          <dd>Cóctel de bienvenida</dd>
        </div>
        <div class="event-row">
          <dt></dt>
          <dd>Plato y postre en mesa</dd>
        </div>
      </dl>

      <a href="https://maps.google.com/?q=Finca+Los+Azahares+Jerez+de+la+Frontera" target="_blank" rel="noopener noreferrer" class="event-map-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        Ver en el mapa
      </a>
    </div>
  </div>
</section>

<style>
  /* Shares .event-section, .event-card, .event-icon, .event-name, .event-info,
     .event-row, .event-map-btn from Ceremony.astro via the cascade */
  .event-section {
    padding: var(--section-padding);
    background: var(--color-bg);
  }

  .event-card {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
  }

  .event-icon {
    color: var(--color-accent);
    display: flex;
    justify-content: center;
    margin-bottom: 1.4rem;
  }

  .event-name {
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 400;
    margin-bottom: 1.8rem;
  }

  .event-info {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem 1.4rem;
    margin: 0 auto 2.2rem;
    width: fit-content;
    font-size: 0.88rem;
  }

  .event-row { display: contents; }

  .event-row dt {
    color: var(--color-text);
    font-weight: 500;
    text-align: right;
    white-space: nowrap;
  }

  .event-row dd {
    color: var(--color-text-light);
    text-align: left;
  }

  .event-map-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.75rem 2rem;
    transition: background 0.25s, color 0.25s;
  }

  .event-map-btn:hover {
    background: var(--color-accent);
    color: white;
  }
</style>
