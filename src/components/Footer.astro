<footer class="footer">
  <div class="footer-inner">
    <p class="footer-names">Ana <em>&amp;</em> Emi</p>
    <div class="footer-rule"></div>
    <p class="footer-date">13 · 03 · 2027</p>
    <p class="footer-quote">
      "Odio el Amor"
    </p>
    <p class="footer-author">— Antoine de Saint-Exupéry</p>
    <div class="footer-ornament" aria-hidden="true">✦</div>
  </div>
</footer>

<style>
  .footer {
    background: #3C3C3C;
    color: rgba(255,255,255,0.6);
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .footer-inner {
    max-width: 480px;
    margin: 0 auto;
  }

  .footer-names {
    font-family: var(--font-script);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: white;
    margin-bottom: 1.2rem;
    letter-spacing: 0.04em;
  }

  .footer-names em {
    font-style: italic;
    color: #96A493;
  }

  .footer-rule {
    width: 40px;
    height: 1px;
    background: rgba(255,255,255,0.2);
    margin: 0 auto 1.2rem;
  }

  .footer-date {
    font-size: 0.75rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 2.5rem;
  }

  .footer-quote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.8;
    margin-bottom: 0.6rem;
  }

  .footer-author {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 2.5rem;
  }

  .footer-ornament {
    font-size: 0.85rem;
    color: #96A493;
    opacity: 0.5;
    letter-spacing: 0.5em;
  }
</style>
