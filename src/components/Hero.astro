---
---
<svg class="wc-defs" aria-hidden="true" focusable="false">
  <defs>
    <filter id="wc-hero" x="-20%" y="-20%" width="140%" height="140%" color-interpolation-filters="sRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.038 0.055" numOctaves="6" seed="12" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="16" xChannelSelector="R" yChannelSelector="G" result="warped"/>
      <feGaussianBlur in="warped" stdDeviation="1.1" result="soft"/>
      <feColorMatrix in="soft" type="saturate" values="0.6" result="faded"/>
      <feComponentTransfer in="faded">
        <feFuncR type="linear" slope="0.93" intercept="0.06"/>
        <feFuncG type="linear" slope="0.91" intercept="0.05"/>
        <feFuncB type="linear" slope="0.86" intercept="0.07"/>
      </feComponentTransfer>
    </filter>
  </defs>
</svg>

<section id="inicio" class="hero">
  <div class="hero-img hero-img--left">
    <img src="/Las-murallas-Reales-de-Ceuta6.jpg" alt="Las Murallas Reales de Ceuta" />
  </div>

  <div class="hero-content">
    <p class="hero-pre">Os invitamos a nuestra boda</p>
    <div class="hero-ornament">✦</div>
    <h1 class="hero-names">Ana <em>&amp;</em> Emi</h1>
    <div class="hero-rule"></div>
    <p class="hero-date">Sábado, 13 de Marzo de 2027</p>
    <div class="hero-location">
      <span class="hero-location-venue">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        Finca Los Azahares
      </span>
      <span class="hero-location-city">Jerez de la Frontera</span>
    </div>

    <a href="#confirmar" class="hero-cta">Confirmar Asistencia</a>
  </div>

  <div class="hero-img hero-img--right">
    <img src="/292552053.jpg" alt="Los novios" />
  </div>

  <a href="#nuestra-historia" class="hero-scroll" aria-label="Desplazarse hacia abajo">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>

<style>
  .wc-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    background: var(--color-surface);
    overflow: hidden;
  }

  /* ── Watercolor images ── */
  .hero-img {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .hero-img--left  { justify-content: flex-end; }
  .hero-img--right { justify-content: flex-start; }

  .hero-img img {
    width: 260px;
    height: 400px;
    object-fit: cover;
    filter: url(#wc-hero);
    display: block;
    flex-shrink: 0;
  }

  /* Left image: fades toward the right (into the dark centre) */
  .hero-img--left img {
    -webkit-mask-image: radial-gradient(ellipse 90% 85% at 40% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
    mask-image:         radial-gradient(ellipse 90% 85% at 40% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
  }

  /* Right image: fades toward the left */
  .hero-img--right img {
    -webkit-mask-image: radial-gradient(ellipse 90% 85% at 60% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
    mask-image:         radial-gradient(ellipse 90% 85% at 60% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
  }

  /* ── Centre text ── */
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: var(--color-text);
    padding: 2rem 2.5rem;
    animation: heroFade 1.4s ease both;
  }

  .hero-pre {
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 1.4rem;
    font-weight: 300;
  }

  .hero-ornament {
    font-size: 1rem;
    color: var(--color-accent);
    margin-bottom: 1.2rem;
    letter-spacing: 0.4em;
  }

  .hero-names {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 4.5rem);
    font-weight: 200;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    white-space: nowrap;
    color: var(--color-text);
  }

  .hero-names em {
    font-style: italic;
    color: var(--color-accent);
  }

  .hero-rule {
    width: 56px;
    height: 1px;
    background: var(--color-border);
    margin: 0 auto 1.5rem;
  }

  .hero-date {
    font-size: clamp(0.72rem, 1.5vw, 0.82rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text);
    font-weight: 300;
    margin-bottom: 0.5rem;
  }

  .hero-location {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 2.8rem;
    font-weight: 300;
  }

  .hero-location-venue {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .hero-location-city {
    padding-left: 1.2rem;
  }

  .hero-cta {
    display: block;
    width: fit-content;
    margin: 0 auto;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 0.9rem 2.4rem;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 400;
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }

  .hero-cta:hover {
    background: var(--color-accent);
    color: white;
  }

  /* ── Scroll arrow ── */
  .hero-scroll {
    position: absolute;
    bottom: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-border);
    animation: scrollBounce 2.2s ease-in-out infinite;
    transition: color 0.3s;
    z-index: 2;
  }

  .hero-scroll:hover { color: var(--color-accent); }

  @keyframes heroFade {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: none; }
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(7px); }
  }

  /* ── Mobile: stack images above/below ── */
  @media (max-width: 780px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      height: auto;
      min-height: 100svh;
      padding: 6rem 0 4rem;
    }

    .hero-img {
      height: 40vw;
      min-height: 160px;
      max-height: 220px;
      justify-content: center;
    }

    .hero-img img {
      width: 200px;
      height: 260px;
    }

    .hero-img--left  { order: 1; }
    .hero-content    { order: 2; }
    .hero-img--right { order: 3; }

    .hero-img--left img,
    .hero-img--right img {
      -webkit-mask-image: radial-gradient(ellipse 90% 85% at 50% 50%, black 25%, rgba(0,0,0,0.5) 60%, transparent 100%);
      mask-image:         radial-gradient(ellipse 90% 85% at 50% 50%, black 25%, rgba(0,0,0,0.5) 60%, transparent 100%);
    }

    .hero-names { white-space: normal; }
    .hero-scroll { display: none; }
  }
</style>
