---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---
<svg class="wc-defs" aria-hidden="true" focusable="false">
  <defs>
    <filter id="wc-hero" x="-20%" y="-20%" width="140%" height="140%" color-interpolation-filters="sRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.038 0.055" numOctaves="6" seed="12" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="16" xChannelSelector="R" yChannelSelector="G" result="warped"/>
      <feGaussianBlur in="warped" stdDeviation="1.1" result="soft"/>
      <feColorMatrix in="soft" type="saturate" values="0.6" result="faded"/>
      <feComponentTransfer in="faded">
        <feFuncR type="linear" slope="0.93" intercept="0.06"/>
        <feFuncG type="linear" slope="0.91" intercept="0.05"/>
        <feFuncB type="linear" slope="0.86" intercept="0.07"/>
      </feComponentTransfer>
    </filter>
  </defs>
</svg>

<section id="inicio" class="hero">
  <div class="hero-img hero-img--left">
    <img src={`${base}murallas-acuarela.png`} alt="Las Murallas Reales de Ceuta" class="no-wc" />
  </div>

  <div class="hero-content">
    <p class="hero-pre">Os invitamos a nuestra boda</p>
    <div class="hero-ornament">✦</div>
    <h1 class="hero-names">
      <span class="hero-name-pair">
        <img src={`${base}icon-bellota.png`} class="hero-icon" alt="" aria-hidden="true" />
        Ana
      </span>
      <em>&amp;</em>
      <span class="hero-name-pair">
        Emi
        <img src={`${base}icon-dedal.png`} class="hero-icon hero-icon--flip" alt="" aria-hidden="true" />
      </span>
    </h1>
    <div class="hero-rule"></div>
    <p class="hero-date">Sábado, 13 de Marzo de 2027</p>
    <div class="hero-location">
      <span class="hero-location-venue">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        Finca Los Azahares
      </span>
      <span class="hero-location-city">Jerez de la Frontera</span>
    </div>

    <a href="#confirmar" class="hero-cta">Confirmar Asistencia</a>
  </div>

  <div class="hero-img hero-img--right">
    <img src={`${base}puerto-acuarela2.png`} alt="Puerto de Ceuta" class="no-wc" />
  </div>

  <a href="#nuestra-historia" class="hero-scroll" aria-label="Desplazarse hacia abajo">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>

<style>
  .wc-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    background: #F0EEE9;
    overflow: hidden;
  }

  /* ── Watercolor images ── */
  .hero-img {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .hero-img--left  { justify-content: flex-end; min-width: 0; }
  .hero-img--right { justify-content: flex-end; min-width: 0; padding-right: 2rem; }

  .hero-img img {
    width: 260px;
    height: 400px;
    object-fit: cover;
    filter: url(#wc-hero);
    display: block;
    flex-shrink: 0;
  }

  .hero-img img.no-wc {
    filter: none;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: 380px;
    object-fit: contain;
    -webkit-mask-image: none;
    mask-image: none;
  }

  .hero-img--right img.no-wc {
    height: min(530px, 60vh);
    max-height: none;
    width: auto;
    max-width: none;
    flex-shrink: 0;
  }

  /* Left image: fades toward the right (into the dark centre) */
  .hero-img--left img {
    -webkit-mask-image: radial-gradient(ellipse 90% 85% at 40% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
    mask-image:         radial-gradient(ellipse 90% 85% at 40% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
  }

  /* Right image: fades toward the left */
  .hero-img--right img {
    -webkit-mask-image: radial-gradient(ellipse 90% 85% at 60% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
    mask-image:         radial-gradient(ellipse 90% 85% at 60% 50%, black 25%, rgba(0,0,0,0.55) 55%, transparent 100%);
  }

  /* ── Centre text ── */
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: var(--color-text);
    padding: 2rem 2.5rem;
    animation: heroFade 1.4s ease both;
  }

  .hero-pre {
    font-family: var(--font-script);
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    text-transform: none;
    color: var(--color-text-light);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .hero-ornament {
    font-size: 1rem;
    color: var(--color-text-light);
    margin-bottom: 1.2rem;
    letter-spacing: 0.4em;
  }

  .hero-names {
    font-family: var(--font-script);
    font-size: clamp(2.2rem, 4vw, 4.5rem);
    font-weight: 200;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    white-space: nowrap;
    color: var(--color-text);
  }

  .hero-names em {
    font-style: italic;
    color: rgba(0, 0, 0, 0.20);
  }

  .hero-name-pair {
    display: inline-flex;
    align-items: center;
    gap: 0;
  }

  .hero-icon {
    width: 0.95em;
    height: 0.95em;
    object-fit: contain;
    display: inline-block;
    vertical-align: middle;
    filter: none;
    opacity: 0.15;
    margin-right: -0.05em;
  }

  .hero-icon--flip {
    width: 1.1em;
    height: 1.1em;
    transform: scaleX(-1);
    opacity: 0.15;
    margin-left: -0.25em;
  }

  .hero-rule {
    width: 56px;
    height: 1px;
    background: var(--color-border);
    margin: 0 auto 1.5rem;
  }

  .hero-date {
    font-family: var(--font-script);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    letter-spacing: 0.04em;
    text-transform: none;
    color: var(--color-text);
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .hero-location {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-script);
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    letter-spacing: 0.03em;
    text-transform: none;
    color: var(--color-text-light);
    margin-bottom: 2.8rem;
    font-weight: 400;
  }

  .hero-location-venue {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .hero-location-city {
    padding-left: 1.2rem;
  }

  .hero-cta {
    display: block;
    width: fit-content;
    margin: 0 auto;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 0.9rem 2.4rem;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 400;
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }

  .hero-cta:hover {
    background: var(--color-accent);
    color: white;
  }

  /* ── Scroll arrow ── */
  .hero-scroll {
    position: absolute;
    bottom: 2.2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-border);
    animation: scrollBounce 2.2s ease-in-out infinite;
    transition: color 0.3s;
    z-index: 2;
  }

  .hero-scroll:hover { color: var(--color-accent); }

  @keyframes heroFade {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: none; }
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(7px); }
  }

  /* ── Mobile: stacked layout ── */
  @media (max-width: 780px) {
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100svh;
      min-height: 580px;
      padding: 2rem 1rem;
      gap: 0;
    }

    .hero-img {
      height: auto;
      width: 100%;
      justify-content: center;
      padding-right: 0;
    }

    .hero-img--left  { order: 1; }
    .hero-content    { order: 2; }
    .hero-img--right { order: 3; }

    .hero-img img,
    .hero-img img.no-wc {
      height: 140px;
      width: auto;
      max-height: none;
      max-width: 60vw;
      object-fit: contain;
    }

    .hero-img--right img.no-wc,
    .hero-img--left  img.no-wc {
      height: 140px;
      max-height: none;
    }

    .hero-names {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      flex-wrap: nowrap;
      white-space: nowrap;
      font-size: clamp(1.2rem, 5.5vw, 2.2rem);
      gap: 0.3em;
      margin-bottom: 1rem;
    }

    .hero-name-pair {
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
    }

    .hero-scroll { display: none; }
  }
</style>
