---
---
<section id="ceremonia" class="event-section event-section--alt">
  <div class="container">
    <h2 class="section-title reveal">La Ceremonia</h2>
    <div class="section-divider reveal"><span>✦</span></div>

    <div class="event-card reveal">
      <div class="event-icon" aria-hidden="true">
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="22" y1="4" x2="22" y2="10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <polyline points="18,9 22,4 26,9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <rect x="9" y="16" width="26" height="24" rx="0.5" stroke="currentColor" stroke-width="1.3"/>
          <rect x="16" y="27" width="12" height="13" stroke="currentColor" stroke-width="1.3"/>
          <line x1="17" y1="22" x2="27" y2="22" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
      </div>

      <h3 class="event-name">Finca Los Azahares</h3>

      <dl class="event-info">
        <div class="event-row">
          <dt>Fecha</dt>
          <dd>Sábado, 13 de Marzo de 2027</dd>
        </div>
        <div class="event-row">
          <dt>Hora</dt>
          <dd>12:00 h</dd>
        </div>
        <div class="event-row">
          <dt>Lugar</dt>
          <dd>Jerez de la Frontera</dd>
        </div>
      </dl>

      <a href="https://maps.google.com/?q=Finca+Los+Azahares+Jerez+de+la+Frontera" target="_blank" rel="noopener noreferrer" class="event-map-btn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        Ver en el mapa
      </a>
    </div>
  </div>
</section>

<style>
  .event-section {
    padding: var(--section-padding);
    background: var(--color-bg);
  }

  .event-section--alt {
    background: var(--color-surface);
  }

  .event-card {
    max-width: 480px;
    margin: 0 auto;
    text-align: center;
  }

  .event-icon {
    color: var(--color-accent);
    display: flex;
    justify-content: center;
    margin-bottom: 1.4rem;
  }

  .event-name {
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 400;
    margin-bottom: 1.8rem;
  }

  .event-info {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.55rem 1.4rem;
    margin: 0 auto 2.2rem;
    width: fit-content;
    font-size: 0.88rem;
  }

  .event-row { display: contents; }

  .event-row dt {
    color: var(--color-text);
    font-weight: 500;
    text-align: right;
    white-space: nowrap;
  }

  .event-row dd {
    color: var(--color-text-light);
    text-align: left;
  }

  .event-map-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    padding: 0.75rem 2rem;
    transition: background 0.25s, color 0.25s;
  }

  .event-map-btn:hover {
    background: var(--color-accent);
    color: white;
  }
</style>
