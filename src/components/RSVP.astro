---
const FORM_URL = 'https://docs.google.com/forms/d/e/1FAIpQLSeqGPhGAVZ0fFxHuAwpx3OQB_0HYiF8Kx8ndgx83rCSBVKCqQ/viewform';
---
<section id="confirmar" class="rsvp-section">
  <div class="container">
    <h2 class="section-title reveal">Confirmar Asistencia</h2>
    <div class="section-divider reveal"><span>✦</span></div>

    <p class="rsvp-intro reveal">
      Confirmad vuestra asistencia antes del <strong>31 de enero de 2027</strong>.<br/>
      Vuestra presencia hace este día todavía más especial.
    </p>

    <div class="rsvp-cta reveal">
      <a href={FORM_URL} target="_blank" rel="noopener noreferrer" class="rsvp-btn">
        Confirmar Asistencia
      </a>
    </div>
  </div>
</section>

<style>
  .rsvp-section {
    padding: var(--section-padding);
    background: var(--color-surface);
  }

  .rsvp-intro {
    max-width: 540px;
    margin: 0 auto 3rem;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }

  .rsvp-intro strong { color: var(--color-text); }

  .rsvp-cta {
    text-align: center;
  }

  .rsvp-btn {
    display: inline-block;
    background: var(--color-accent);
    color: white;
    padding: 1rem 3.5rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: background 0.25s;
  }

  .rsvp-btn:hover {
    background: var(--color-accent-dark);
    color: white;
  }
</style>
