---
---
<!-- Hidden SVG filter definitions for watercolor effect -->
<svg class="wc-defs" aria-hidden="true" focusable="false">
  <defs>
    <filter id="wc" x="-20%" y="-20%" width="140%" height="140%" color-interpolation-filters="sRGB">
      <!-- Watery displacement -->
      <feTurbulence type="fractalNoise" baseFrequency="0.038 0.055" numOctaves="6" seed="12" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="16" xChannelSelector="R" yChannelSelector="G" result="warped"/>
      <!-- Painterly softness -->
      <feGaussianBlur in="warped" stdDeviation="1.1" result="soft"/>
      <!-- Wash out saturation -->
      <feColorMatrix in="soft" type="saturate" values="0.6" result="faded"/>
      <!-- Warm paper tone -->
      <feComponentTransfer in="faded">
        <feFuncR type="linear" slope="0.93" intercept="0.06"/>
        <feFuncG type="linear" slope="0.91" intercept="0.05"/>
        <feFuncB type="linear" slope="0.86" intercept="0.07"/>
      </feComponentTransfer>
    </filter>
  </defs>
</svg>

<section class="photoduo">
  <div class="photoduo-img photoduo-img--left reveal">
    <img src="/Las-murallas-Reales-de-Ceuta6.jpg" alt="Las Murallas Reales de Ceuta" />
  </div>

  <div class="photoduo-text reveal">
    <span class="photoduo-ornament" aria-hidden="true">✦</span>
    <h2 class="photoduo-names">Nombre <em>&amp;</em> Nombre</h2>
    <div class="photoduo-rule"></div>
    <p class="photoduo-date">00 · 09 · 2025</p>
    <p class="photoduo-place">Ceuta, España</p>
  </div>

  <div class="photoduo-img photoduo-img--right reveal">
    <img src="/292552053.jpg" alt="Los novios" />
  </div>
</section>

<style>
  .wc-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .photoduo {
    display: grid;
    grid-template-columns: 1fr min-content 1fr;
    align-items: center;
    gap: 2rem 3rem;
    padding: 5rem 4rem;
    background: var(--color-bg);
  }

  /* ── Images ── */
  .photoduo-img {
    display: flex;
    justify-content: center;
  }

  .photoduo-img img {
    display: block;
    width: 100%;
    max-width: 280px;
    height: 370px;
    object-fit: cover;
    /* Watercolor colour treatment */
    filter: url(#wc);
  }

  /* Soft bleeding edges — left image fades toward the right */
  .photoduo-img--left img {
    -webkit-mask-image: radial-gradient(ellipse 88% 90% at 55% 50%, black 28%, rgba(0,0,0,0.5) 58%, transparent 100%);
    mask-image:         radial-gradient(ellipse 88% 90% at 55% 50%, black 28%, rgba(0,0,0,0.5) 58%, transparent 100%);
  }

  /* Right image fades toward the left */
  .photoduo-img--right img {
    -webkit-mask-image: radial-gradient(ellipse 88% 90% at 45% 50%, black 28%, rgba(0,0,0,0.5) 58%, transparent 100%);
    mask-image:         radial-gradient(ellipse 88% 90% at 45% 50%, black 28%, rgba(0,0,0,0.5) 58%, transparent 100%);
  }

  /* ── Centre text ── */
  .photoduo-text {
    text-align: center;
    min-width: 200px;
    padding: 0 1.5rem;
  }

  .photoduo-ornament {
    display: block;
    font-size: 0.85rem;
    color: var(--color-accent);
    letter-spacing: 0.35em;
    margin-bottom: 1.3rem;
  }

  .photoduo-names {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: 400;
    color: var(--color-text);
    white-space: nowrap;
    margin-bottom: 1rem;
  }

  .photoduo-names em {
    font-style: italic;
    color: var(--color-accent);
  }

  .photoduo-rule {
    width: 36px;
    height: 1px;
    background: var(--color-accent);
    opacity: 0.45;
    margin: 0 auto 1rem;
  }

  .photoduo-date {
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: 0.45rem;
  }

  .photoduo-place {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--color-text-light);
  }

  /* ── Mobile ── */
  @media (max-width: 780px) {
    .photoduo {
      grid-template-columns: 1fr;
      padding: 4rem 2rem;
      gap: 2rem;
    }

    .photoduo-img--left  { order: 1; }
    .photoduo-text       { order: 2; }
    .photoduo-img--right { order: 3; }

    .photoduo-img img {
      max-width: 240px;
      height: 300px;
      margin: 0 auto;
    }

    .photoduo-img--left img,
    .photoduo-img--right img {
      -webkit-mask-image: radial-gradient(ellipse 85% 90% at 50% 50%, black 28%, rgba(0,0,0,0.5) 60%, transparent 100%);
      mask-image:         radial-gradient(ellipse 85% 90% at 50% 50%, black 28%, rgba(0,0,0,0.5) 60%, transparent 100%);
    }

    .photoduo-names { white-space: normal; }
  }
</style>
